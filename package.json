{
  "name": "vdmais-fila-inteligente",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "predev": "npm run dev:db",
    "dev": "concurrently --kill-others-on-fail \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:db": "(podman-compose -f compose.dev.yml up -d postgres || docker compose -f compose.dev.yml up -d postgres) && wait-on tcp:127.0.0.1:5432",
    "dev:backend": "npm run dev --workspace=apps/backend",
    "dev:frontend": "wait-on http-get://127.0.0.1:3000/health/ready && npm run dev --workspace=apps/frontend",
    "build": "npm run build --workspace=apps/backend && npm run build --workspace=apps/frontend",
    "test": "npm run test --workspaces --if-present",
    "test:e2e": "npm run test:e2e --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\" --ignore-path .gitignore",
    "sonar:up": "docker compose -f compose.sonar.yml up -d sonarqube",
    "sonar:down": "docker compose -f compose.sonar.yml down",
    "sonar:coverage": "npm run test:cov --workspace=apps/backend && npm run test:cov --workspace=apps/frontend",
    "coverage:changed": "node scripts/check-changed-coverage.mjs",
    "sonar:scan": "docker compose -f compose.sonar.yml run --rm sonar-scanner",
    "sonar": "npm run sonar:coverage && npm run sonar:scan"
  },
  "overrides": {
    "form-data": "4.0.6",
    "ws": "8.21.0",
    "multer": "2.2.0",
    "js-yaml": "^4.2.0",
    "@istanbuljs/load-nyc-config": {
      "js-yaml": "^3.15.0"
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "concurrently": "^10.0.3",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "typescript": "^7.0.2",
    "wait-on": "^9.0.3"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
