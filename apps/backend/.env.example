DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/fila_inteligente?schema=public"
# Use "development" or "test" ONLY locally. Any other value (or leaving it unset)
# enables strict production checks: JWT_SECRET must be strong (>= 32 chars, not a known weak value).
NODE_ENV=development
# In production, generate a strong random secret, e.g.: openssl rand -base64 48
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="7d"
PORT=3000
FRONTEND_URL="http://localhost:5173"
# Required to expose /observability/metrics. Without it the endpoint is disabled (fail closed).
OBSERVABILITY_TOKEN="replace-with-a-random-monitoring-token"
