# ─────────────────────────────────────────────────────────────────────────────
# Backend — variáveis de ambiente (exemplo). Copie para .env e ajuste.
# ─────────────────────────────────────────────────────────────────────────────

# ── Aplicação ────────────────────────────────────────────────────────────────
# "development" | "test" SOMENTE local; outro valor ativa as checagens de produção.
NODE_ENV=development
PORT=3000
FRONTEND_URL="http://localhost:5173"
# Nº de proxies confiáveis à frente do backend (define o req.ip usado no rate-limit).
# Default 1. Render = 1; CDN + load balancer = 2. Valor errado torna o IP falsificável.
TRUST_PROXY_HOPS=1

# ── Rate limit (requisições por minuto) ──────────────────────────────────────
# Requisição autenticada conta por USUÁRIO (JWT verificado); anônima conta por IP.
# Opcionais: default no código, a env apenas sobrescreve. Eleve os limites anônimos
# (register/login) quando muita gente divide o mesmo Wi-Fi/NAT — ex.: convenção.
THROTTLE_GLOBAL_PER_MINUTE=300
THROTTLE_REGISTER_PER_MINUTE=20
THROTTLE_LOGIN_PER_MINUTE=40
THROTTLE_TICKET_CREATE_PER_MINUTE=40

# ── Banco de dados ───────────────────────────────────────────────────────────
DATABASE_URL="postgresql://fila:fila_dev_pass@localhost:5432/fila_inteligente?schema=public"

# ── Autenticação (JWT da equipe e da RE) ─────────────────────────────────────
# Em produção, gere um segredo forte: openssl rand -base64 48
JWT_SECRET="change-me-in-production"
# Validade do JWT da EQUIPE (staff). A sessão da REPRESENTANTE não usa este valor:
# expira sempre no fim do dia útil (a fila é diária).
JWT_EXPIRES_IN="8h"
# Validade dos tokens de entrada por canal, em segundos. Opcionais: default 24h no código,
# a env apenas sobrescreve. O QR digital é regenerado a cada dia (manual hoje; automático
# no DT-12). A sessão da representante expira sempre no fim do dia útil, independente destes.
QUEUE_ENTRY_QR_CODE_TTL_SECONDS=86400
QUEUE_ENTRY_LINK_TTL_SECONDS=86400

# ── Observabilidade ──────────────────────────────────────────────────────────
OBSERVABILITY_TOKEN="replace-with-a-random-monitoring-token"

# ── Integração M2M (sistema legado) ──────────────────────────────────────────
INTEGRATION_JWT_ISSUER="https://dev-local/integration"
INTEGRATION_JWT_AUDIENCE="vdmais-fila-integration"
# Produção/Apigee: URL do JWKS. Dev: vazio (valida pela chave pública local).
INTEGRATION_JWKS_URI=""
INTEGRATION_DOCS_ENABLED="false"

# Emissor de token SÓ de desenvolvimento (desligado fora de development/test).
INTEGRATION_DEV_TOKEN_ENABLED="false"
INTEGRATION_DEV_CLIENT_ID="legacy-erp"
INTEGRATION_DEV_CLIENT_SECRET="troque-este-segredo-de-dev"
INTEGRATION_DEV_ALLOWED_SCOPES="tickets:start tickets:finish"

# Par RS256 em UMA linha (com \n entre as linhas do PEM):
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out dev.key
#   openssl pkey -in dev.key -pubout -out dev.pub
#   awk 'NR>1{printf "\\n"} {printf "%s", $0}' dev.key
INTEGRATION_DEV_PRIVATE_KEY=""
INTEGRATION_DEV_PUBLIC_KEY=""

# ── Admin inicial (seed: npm run db:seed) ────────────────────────────────────
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="troque-esta-senha-forte"
ADMIN_NAME="Admin"
