
# ── Banco de dados ──────────────────────────────────────────────────────────
# Local (podman-compose / docker-compose):
# DATABASE_URL="postgresql://fila:fila_dev_pass@localhost:5432/fila_inteligente?schema=public"
#
# Supabase (produção / teste remoto):
# Substitua [SUPABASE_DB_PASSWORD] pela senha definida ao criar o projeto.
# Host do projeto vdmais-fila-inteligente: db.SUPABASE_PROJECT_REF.supabase.co
DATABASE_URL="postgresql://postgres:[SUPABASE_DB_PASSWORD]@db.SUPABASE_PROJECT_REF.supabase.co:5432/postgres"

# Use "development" ou "test" SOMENTE localmente. Qualquer outro valor (ou ausente)
# ativa checagens de produção: JWT_SECRET deve ter >= 32 chars.
NODE_ENV=production

# Gere um secret forte: openssl rand -base64 48
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="7d"

PORT=3000

# URL pública do frontend (usada no CORS). Preencha após o deploy no Vercel/Render.
FRONTEND_URL="https://SEU_DOMINIO_FRONTEND.vercel.app"

# Token para o endpoint /observability/metrics. Deixe em branco para desabilitar.
OBSERVABILITY_TOKEN="replace-with-a-random-monitoring-token"

# ── Admin inicial (seed) ─────────────────────────────────────────────────────
# Usado apenas pelo comando: npm run db:seed
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="troque-esta-senha-forte"
ADMIN_NAME="Admin"
